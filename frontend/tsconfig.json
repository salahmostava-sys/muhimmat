{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@app/*": [
        "./app/*"
      ],
      "@services/*": [
        "./services/*"
      ],
      "@modules/*": [
        "./modules/*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    },
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}